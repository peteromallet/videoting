    "review::.::holistic::design_coherence::useTimelineData_mixed_responsibilities": {
      "id": "review::.::holistic::design_coherence::useTimelineData_mixed_responsibilities",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "useTimelineData handles data loading, saving, mutations, selection, render status, and preferences",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "viewer/src/tools/video-editor/hooks/useTimelineData.ts"
        ],
        "evidence": [
          "466 lines managing: React Query loading (lines 130-140), save mutation with debouncing (lines 142-198), data materialization (lines 159-181), selection state (lines 117-119, 313-338), render status (lines 121-123, 388-428), and editor preferences (lines 124, 353-378)",
          "The hook returns 30+ values/functions, suggesting it serves too many consumers with too many concerns"
        ],
        "suggestion": "Extract render management (startRender, renderStatus, renderLog, renderDirty) into a useRenderStatus hook. Extract selection state management (selectedClipId, selectedTrackId, selectedClip, selectedTrack) into a useSelectionState hook. This would leave useTimelineData focused on data loading, saving, and mutation.",
