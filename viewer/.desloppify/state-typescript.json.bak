    "review::.::holistic::initialization_coupling::import_time_env_loading": {
      "id": "review::.::holistic::initialization_coupling::import_time_env_loading",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "common.py reads .env file and modifies os.environ at import time",
      "detail": {
        "holistic": true,
        "dimension": "initialization_coupling",
        "related_files": [
          "tools/common.py"
        ],
        "evidence": [
          "Lines 26-32: module-level code reads .env and calls os.environ.setdefault for each key-value pair",
          "Every tool that does 'from common import ...' triggers this side effect, making it impossible to import common without loading .env",
          "In testing, this means environment variables are set before any test can configure its own environment"
        ],
        "suggestion": "Move the .env loading into a load_env() function and call it explicitly in each tool's main() or at the start of the if __name__ == '__main__' block. This preserves the convenience while removing the import-time side effect.",
        "reasoning": "",
        "summary_hash": "4c7a03a1"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-24T05:30:25+00:00",
      "last_seen": "2026-03-24T05:34:05+00:00",
      "resolved_at": null,
      "reopen_count": 0,
      "work_item_kind": "review_defect",
      "issue_kind": "review_defect",
      "origin": "review_import",
      "lang": "typescript",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null
    },
    "review::.::holistic::initialization_coupling::mutable_module_level_cache": {
      "id": "review::.::holistic::initialization_coupling::mutable_module_level_cache",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "common.py has module-level mutable caches (_profile_cache, _profile_paths) shared across all callers",
      "detail": {
        "holistic": true,
        "dimension": "initialization_coupling",
        "related_files": [
          "tools/common.py"
        ],
        "evidence": [
          "Lines 56-57: _profile_cache: dict[str, dict] = {} and _profile_paths: dict[str, Path] = {} are module-level mutable state",
          "load_profile populates _profile_cache as a side effect; get_profile_path depends on _profile_paths being populated by load_profile",
          "These caches persist across calls and cannot be cleared or reset, creating hidden coupling between callers"
        ],
        "suggestion": "These caches are acceptable for CLI tools that run once and exit. Add a brief comment documenting that these caches are intentional for CLI performance and not safe for long-running processes. If testing becomes a concern, add a clear_profile_cache() function.",
        "reasoning": "",
        "summary_hash": "94d0e0aa"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-24T05:30:25+00:00",
