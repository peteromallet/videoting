      "id": "review::.::holistic::type_safety::effect_type_fields_untyped",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "ClipEntrance, ClipExit, ClipContinuous use 'type: string' instead of literal unions matching effect registries",
      "detail": {
        "holistic": true,
        "dimension": "type_safety",
        "related_files": [
          "shared/types.ts",
          "shared/effects/index.tsx"
        ],
        "evidence": [
          "types.ts line 30 ClipEntrance.type is 'string', but valid values are the keys of entranceEffects in effects/index.tsx: 'slide-up' | 'slide-down' | 'slide-left' | 'slide-right' | 'zoom-in' | 'zoom-spin' | 'pulse' | 'fade' | 'flip' | 'bounce'. Same pattern for ClipExit and ClipContinuous."
        ],
        "suggestion": "Define literal union types (e.g., type EntranceEffectType = 'slide-up' | 'slide-down' | ... ) derived from the registry keys using keyof typeof, and use these in ClipEntrance, ClipExit, and ClipContinuous type definitions. This provides compile-time validation of effect type strings.",
