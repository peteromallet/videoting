    "review::.::holistic::type_safety::upload_asset_double_json_parse": {
      "id": "review::.::holistic::type_safety::upload_asset_double_json_parse",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "uploadAssetFile calls response.json() twice \u2014 once for error, once for success \u2014 and the success return is a dangling promise",
      "detail": {
        "holistic": true,
        "dimension": "type_safety",
        "related_files": [
          "viewer/src/tools/video-editor/lib/timeline-api.ts"
        ],
        "evidence": [
          "Lines 40-44: On error, 'await response.json()' is called. On success (line 44), 'return response.json()' returns a Promise without await. This means the function's return type is Promise<unknown> where the actual return is a Promise<unknown> (unawaited json()). The caller ignores the return value, so this doesn't cause runtime bugs, but the contract is misleading."
        ],
        "suggestion": "Add await to the success path: 'return await response.json()' \u2014 or if the return value is truly unused, change the return type to Promise<void> and don't return the json body.",
        "reasoning": "",
        "summary_hash": "96e34cca"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-24T04:32:07+00:00",
      "last_seen": "2026-03-24T04:32:07+00:00",
      "resolved_at": null,
