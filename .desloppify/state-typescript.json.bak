    "review::.::holistic::contract_coherence::unsafe_cast_serialize_clip": {
      "id": "review::.::holistic::contract_coherence::unsafe_cast_serialize_clip",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "serializeClipForDisk uses 'as TimelineClip' cast on a Partial, hiding missing required fields",
      "detail": {
        "holistic": true,
        "dimension": "contract_coherence",
        "related_files": [
          "shared/serialize.ts"
        ],
        "evidence": [
          "Line 60: 'return serializedClip as TimelineClip' \u2014 serializedClip is typed as Partial<Record<TimelineClipField, ...>> which does not guarantee that required TimelineClip fields (id, at, track) are present. While the code manually sets id, at, and track above, the type system doesn't verify this."
        ],
        "suggestion": "Build the return value starting from a properly typed base object { id: clip.id, at: clip.at, track: clip.track } and spread optional fields onto it, so the return type is structurally guaranteed to satisfy TimelineClip without a cast.",
        "reasoning": "",
        "summary_hash": "7e944376"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-24T04:32:07+00:00",
